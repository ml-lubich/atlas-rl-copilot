# Copy to `.env` and fill in. Never commit `.env`.
# Get keys from your MiniMax developer console.

MINIMAX_API_KEY=
# Optional overrides:
# MINIMAX_API_BASE=https://api.minimax.io
# MINIMAX_MODEL=MiniMax-M2.5

# Optional: OpenAI for CrewAI path (only if ATLAS_USE_CREW=1 and no MiniMax key)
# OPENAI_API_KEY=
# ATLAS_USE_CREW=0
